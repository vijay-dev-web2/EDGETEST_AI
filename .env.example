# ============================================================
# EdgeTest AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in all required values.
# Generate random secrets with: openssl rand -base64 32
# ============================================================


# ------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------

# Required — OpenAI API key for GPT-4o
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — Anthropic API key (reserved for future Claude support)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# LLM model to use (default: gpt-4o)
LLM_MODEL=gpt-4o


# ------------------------------------------------------------
# GitHub OAuth
# ------------------------------------------------------------

# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ------------------------------------------------------------
# NextAuth (Frontend)
# ------------------------------------------------------------

# Random secret — run: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the Next.js app
NEXTAUTH_URL=http://localhost:3000


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Full asyncpg connection URL for the FastAPI backend
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edgetest

# Individual credentials used by docker-compose to create the database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edgetest


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

# Redis connection URL (used by both FastAPI and Celery)
REDIS_URL=redis://localhost:6379/0

# Celery broker and result backend (can both point to Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ------------------------------------------------------------
# Authentication (Backend)
# ------------------------------------------------------------

# JWT signing secret — run: openssl rand -base64 32
JWT_SECRET=

# JWT access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fernet encryption key for sensitive fields stored in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Environment name: development | staging | production
APP_ENV=development

# Frontend origin allowed by the FastAPI CORS middleware
FRONTEND_URL=http://localhost:3000


# ------------------------------------------------------------
# Docker Sandbox
# ------------------------------------------------------------

# Docker image used to execute generated tests in isolation
SANDBOX_IMAGE=edgetest-sandbox:latest

# Maximum seconds to wait for a sandbox test run (default: 30)
SANDBOX_TIMEOUT=30


# ------------------------------------------------------------
# Observability (Optional)
# ------------------------------------------------------------

# Sentry DSN for error tracking — leave blank to disable
# Get yours at: https://sentry.io
SENTRY_DSN=


# ------------------------------------------------------------
# Coverage Threshold
# ------------------------------------------------------------

# Minimum coverage % required to pass the coverage gate (0-100)
COVERAGE_THRESHOLD=80

# Set to false to disable the coverage gate without removing the threshold
COVERAGE_THRESHOLD_ENABLED=true
